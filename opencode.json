{
  "$schema": "https://opencode.ai/config.json",
  "command": {
    "review": {
      "template": "Check existing changes for potential bugs and security issues",
      "description": "Review existing changes",
      "agent": "review"
    }
  },
  "lsp": {
    "pyright": {
      "disabled": true
    },
    "ty": {
      "command": ["uvx", "ty", "server"],
      "extensions": [".py", ".pyi"]
    }
  },
  "agent": {
    "plan": {
      "temperature": 0.3,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "build": {
      "temperature": 0.7,
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "review": {
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      }
    }
  }
}
